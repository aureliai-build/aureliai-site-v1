---
interface Props {
  eyebrow: string;
  title: string;
  description: string;
}

const { eyebrow, title, description } = Astro.props;
---

<section class="px-4 pb-12 pt-16 sm:px-6 sm:pt-20 lg:px-8">
  <div class="mx-auto max-w-4xl text-center">
    <p class="text-sm font-semibold uppercase tracking-[0.2em] text-brand">{eyebrow}</p>
    <h1 class="mt-4 text-4xl font-bold tracking-tight sm:text-5xl">
      <span class="text-gradient">{title}</span>
    </h1>
    <p class="mx-auto mt-5 max-w-2xl text-lg text-muted">{description}</p>
  </div>
</section>

---
import { faqs } from '../data/site';
---

<section class="px-4 py-20 sm:px-6 lg:px-8">
  <div class="mx-auto max-w-3xl">
    <div class="mb-12 text-center">
      <h2 class="text-3xl font-bold tracking-tight sm:text-4xl">
        Frequently asked <span class="text-gradient">questions</span>
      </h2>
      <p class="mt-4 text-lg text-muted">What teams usually ask before starting a pilot.</p>
    </div>

    <div class="space-y-4">
      {
        faqs.map((faq) => (
          <details class="group glass rounded-2xl px-5 py-4 open:border-brand/30">
            <summary class="flex cursor-pointer items-center justify-between gap-4 font-medium">
              <span>{faq.question}</span>
              <span class="text-brand transition group-open:rotate-45">+</span>
            </summary>
            <p class="mt-3 text-sm leading-relaxed text-muted">{faq.answer}</p>
          </details>
        ))
      }
    </div>
  </div>
</section>

---
import { projects } from '../data/site';

interface Props {
  showIntro?: boolean;
}

const { showIntro = true } = Astro.props;
---

<section class="px-4 py-20 sm:px-6 lg:px-8">
  <div class="mx-auto max-w-6xl">
    {
      showIntro && (
        <div class="mx-auto mb-14 max-w-2xl text-center">
          <h2 class="text-3xl font-bold tracking-tight sm:text-4xl">
            Selected <span class="text-gradient">projects</span>
          </h2>
          <p class="mt-4 text-lg text-muted">
            Prototypes and systems we are building to demonstrate practical AI in production.
          </p>
        </div>
      )
    }

    <div class="grid gap-6 lg:grid-cols-3">
      {
        projects.map((project) => (
          <article class="glass flex flex-col rounded-2xl p-6 transition hover:border-brand/30">
            <h3 class="text-lg font-semibold">{project.title}</h3>
            <p class="mt-3 flex-1 text-sm leading-relaxed text-muted">{project.description}</p>
            <a
              href={project.url}
              target="_blank"
              rel="noreferrer"
              class="mt-6 inline-flex w-fit rounded-full border border-card-border px-4 py-2 text-sm font-medium transition hover:border-brand/40 hover:text-brand"
            >
              View on GitHub →
            </a>
          </article>
        ))
      }
    </div>
  </div>
</section>

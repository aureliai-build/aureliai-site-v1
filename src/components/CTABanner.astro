---
import { site } from '../data/site';
---

<section class="px-4 py-20 sm:px-6 lg:px-8">
  <div class="mx-auto max-w-5xl">
    <div class="relative overflow-hidden rounded-3xl border border-brand/20 bg-gradient-to-br from-brand/10 via-card to-indigo-500/10 px-8 py-14 text-center sm:px-12">
      <h2 class="text-3xl font-bold tracking-tight sm:text-4xl">Ready to explore your use case?</h2>
      <p class="mx-auto mt-4 max-w-2xl text-muted">
        Tell us about your workflow, data, and goals. We will suggest a practical path forward.
      </p>
      <div class="mt-8 flex flex-wrap justify-center gap-4">
        <a
          href="/contact"
          class="inline-flex rounded-full bg-brand px-6 py-3 font-semibold text-slate-950 transition hover:bg-brand-strong"
        >
          Contact Us
        </a>
        <a
          href={`mailto:${site.email}`}
          class="inline-flex rounded-full border border-card-border glass px-6 py-3 font-semibold transition hover:border-brand/40"
        >
          Email us
        </a>
      </div>
    </div>
  </div>
</section>

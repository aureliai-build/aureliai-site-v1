---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';
import FeatureGrid from '../components/FeatureGrid.astro';
import EngagementModels from '../components/EngagementModels.astro';
import CTABanner from '../components/CTABanner.astro';
---

<BaseLayout title="Services" current="services">
  <PageHero
    eyebrow="Services"
    title="AI solutions built for your business"
    description="From prototypes to production systems, we help teams adopt AI with clarity, security, and measurable outcomes."
  />
  <FeatureGrid
    title="What we"
    titleAccent="deliver"
    subtitle="End-to-end consulting across knowledge systems, documents, and automation."
  />
  <EngagementModels />
  <CTABanner />
</BaseLayout>

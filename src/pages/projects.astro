---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';
import ProjectGrid from '../components/ProjectGrid.astro';
import CTABanner from '../components/CTABanner.astro';
---

<BaseLayout title="Projects" current="projects">
  <PageHero
    eyebrow="Projects"
    title="Selected work & prototypes"
    description="A sample of systems we have built or are actively developing. Personal and internal projects are a great place to start."
  />
  <ProjectGrid showIntro={false} />
  <CTABanner />
</BaseLayout>

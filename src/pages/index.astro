---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import FeatureGrid from '../components/FeatureGrid.astro';
import Pillars from '../components/Pillars.astro';
import ProjectGrid from '../components/ProjectGrid.astro';
import EngagementModels from '../components/EngagementModels.astro';
import FAQ from '../components/FAQ.astro';
import CTABanner from '../components/CTABanner.astro';
---

<BaseLayout title="Home" current="home">
  <Hero />
  <FeatureGrid limit={4} title="Core services for" titleAccent="modern teams" />
  <Pillars />
  <ProjectGrid />
  <EngagementModels />
  <FAQ />
  <CTABanner />
</BaseLayout>

---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Contact" current="contact">
  <section class="hero">
    <div class="container">
      <p class="eyebrow">Contact</p>
      <h1>Let&apos;s talk about your next AI project</h1>
      <p class="lead">
        Reach out with a short description of your use case. We typically respond within one business day.
      </p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="card">
        <ul class="contact-list">
          <li>
            <strong>Email</strong><br />
            <a href="mailto:aureliai.common@gmail.com">aureliai.common@gmail.com</a>
          </li>
          <li>
            <strong>LinkedIn</strong><br />
            <a href="https://www.linkedin.com/company/aureliai-ai" target="_blank" rel="noreferrer">
              Aurelia AI on LinkedIn
            </a>
          </li>
          <li>
            <strong>GitHub</strong><br />
            <a href="https://github.com/aureliai-build" target="_blank" rel="noreferrer">
              github.com/aureliai-build
            </a>
          </li>
        </ul>
      </div>
    </div>
  </section>
</BaseLayout>
